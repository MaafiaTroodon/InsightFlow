generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Dataset {
  id                   String        @id @default(cuid())
  userId               String?
  name                 String
  originalFileName     String
  fileType             String?
  rawRowCount          Int?
  rowCount             Int
  duplicateRowsRemoved Int           @default(0)
  missingValuesFixed   Int           @default(0)
  warnings             Json?
  createdAt            DateTime      @default(now())
  user                 User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rows                 BusinessRow[]

  @@index([userId])
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  datasets     Dataset[]
}

model BusinessRow {
  id           String   @id @default(cuid())
  datasetId    String
  projectName  String
  clientName   String?
  status       String?
  date         DateTime?
  revenue      Decimal  @db.Decimal(18, 2)
  cost         Decimal  @db.Decimal(18, 2)
  budget       Decimal? @db.Decimal(18, 2)
  profit       Decimal  @db.Decimal(18, 2)
  margin       Decimal  @db.Decimal(7, 4)
  isOverBudget Boolean  @default(false)
  rawJson      Json
  createdAt    DateTime @default(now())
  dataset      Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId])
}
